<% if scheduled_action.errors.any? %>
  <div>
    <h2><%= pluralize(scheduled_action.errors.count, "error") %> prohibited this scheduled action from being saved:</h2>
    <ul>
      <% scheduled_action.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: [bot, scheduled_action] do |form| %>
  <div>
    <%= form.label :name %>
    <%= form.text_field :name, required: true, placeholder: "Morning greeting" %>
  </div>

  <div>
    <%= form.label :schedule %>
    <%= form.text_field :schedule, required: true, placeholder: "every 1h" %>
    <small>Examples: every 30m, every 1h, every 1d</small>
  </div>

  <%= form.hidden_field :action_type, value: "send_message" %>

  <div>
    <%= form.label :action_config, "Action config (JSON)" %>
    <%= form.text_area :action_config, required: true, rows: 3, placeholder: '{"group_id": "...", "message": "Good morning!"}' %>
  </div>

  <div>
    <%= form.label :enabled %>
    <%= form.check_box :enabled %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
