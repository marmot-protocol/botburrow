<% if scheduled_action.errors.any? %>
  <div class="mb-4 rounded-md border border-danger/30 bg-danger/10 px-4 py-3 text-sm text-danger">
    <ul class="list-disc pl-4">
      <% scheduled_action.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: [bot, scheduled_action] do |form| %>
  <div class="grid lg:grid-cols-[minmax(0,1fr)_minmax(0,2fr)] gap-6">
    <%# Left column: form fields %>
    <div class="space-y-4">
      <div>
        <%= form.label :name, class: "block text-sm font-medium text-text-muted mb-1" %>
        <%= form.text_field :name, required: true, placeholder: "Morning greeting",
          class: "w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text placeholder:text-text-faint focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary" %>
      </div>

      <div>
        <%= form.label :schedule, "Schedule (cron)", class: "block text-sm font-medium text-text-muted mb-1" %>
        <%= form.text_field :schedule, required: true, placeholder: "0 9 * * *",
          class: "w-full rounded-md border border-border bg-surface px-3 py-2 text-sm font-mono text-text placeholder:text-text-faint focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary" %>
        <p class="mt-1 text-xs text-text-faint">
          <code class="text-primary">* * * * *</code> = every minute,
          <code class="text-primary">*/30 * * * *</code> = every 30 min,
          <code class="text-primary">0 9 * * *</code> = daily at 9am,
          <code class="text-primary">0 9 * * 1</code> = Mondays at 9am
        </p>
      </div>

      <div>
        <p class="block text-sm font-medium text-text-muted mb-2">Groups</p>
        <% active_groups = groups.select { |g| g[:state] == "active" } %>
        <% selected_ids = scheduled_action.group_ids || [] %>
        <% if active_groups.any? %>
          <div class="space-y-2 rounded-md border border-border bg-surface p-3 max-h-48 overflow-y-auto">
            <% active_groups.each do |g| %>
              <label class="flex items-center gap-2 cursor-pointer text-sm text-text hover:text-primary transition-colors">
                <input type="checkbox" name="scheduled_action[group_ids][]" value="<%= g[:id] %>"
                  <%= "checked" if selected_ids.include?(g[:id]) %>
                  class="rounded border-border bg-surface text-primary focus:ring-primary">
                <span><%= g[:name] %></span>
                <span class="text-xs text-text-faint">(<%= g[:id].first(8) %>...)</span>
              </label>
            <% end %>
          </div>
          <%# Empty array fallback when no checkboxes are checked %>
          <input type="hidden" name="scheduled_action[group_ids][]" value="">
        <% else %>
          <p class="text-sm text-text-faint">No groups found. Invite the bot to a group first.</p>
        <% end %>
      </div>

      <div class="flex items-center gap-2">
        <%= form.check_box :enabled, class: "rounded border-border bg-surface text-primary focus:ring-primary" %>
        <%= form.label :enabled, class: "text-sm text-text-muted" %>
      </div>

      <div class="flex gap-3">
        <%= form.submit class: "rounded-md bg-primary px-4 py-2 text-sm font-medium text-white hover:bg-primary-hover transition-colors cursor-pointer" %>
        <%= link_to "Cancel", bot_path(bot, anchor: "schedules"),
          class: "rounded-md px-4 py-2 text-sm font-medium text-text-muted border border-border hover:bg-surface-overlay transition-colors" %>
      </div>
    </div>

    <%# Right column: script editor %>
    <div>
      <%= render "shared/script_editor", form: form, field_name: :script_body %>
    </div>
  </div>
<% end %>
