<% if webhook_endpoint.errors.any? %>
  <div>
    <h2><%= pluralize(webhook_endpoint.errors.count, "error") %> prohibited this webhook endpoint from being saved:</h2>
    <ul>
      <% webhook_endpoint.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: [bot, webhook_endpoint] do |form| %>
  <div>
    <%= form.label :name %>
    <%= form.text_field :name, required: true, placeholder: "My Webhook" %>
  </div>

  <div>
    <%= form.label :url %>
    <%= form.text_field :url, required: true, placeholder: "https://example.com/webhook" %>
  </div>

  <div>
    <%= form.label :secret %>
    <%= form.text_field :secret, placeholder: "Optional HMAC secret" %>
    <small>Used to sign webhook payloads with HMAC-SHA256.</small>
  </div>

  <div>
    <%= form.label :enabled %>
    <%= form.check_box :enabled %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
