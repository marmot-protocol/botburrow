<%= turbo_stream_from @bot %>

<div class="mb-6 flex flex-wrap items-center justify-between gap-4">
  <div class="flex items-center gap-4">
    <%= bot_avatar(@bot, size: 12) %>
    <div>
      <h1 class="text-xl font-semibold"><%= @bot.name %></h1>
      <% if @bot.description.present? %>
        <p class="mt-1 text-sm text-text-muted"><%= @bot.description %></p>
      <% end %>
    </div>
  </div>
  <%= render "bots/status_bar", bot: @bot %>
</div>

<div data-controller="tabs">
  <div class="mb-6 flex gap-6 border-b border-border overflow-x-auto">
    <% %w[overview commands triggers schedules files logs].each_with_index do |tab, i| %>
      <button data-tabs-target="tab" data-tabs-id="<%= tab %>" data-action="tabs#select"
        class="whitespace-nowrap border-b-2 pb-3 text-sm font-medium transition-colors
               <%= i == 0 ? 'border-primary text-text' : 'border-transparent text-text-muted' %>
               hover:text-text">
        <%= tab.capitalize %>
      </button>
    <% end %>
    <%= link_to "Chat", bot_chat_path(@bot),
      class: "whitespace-nowrap border-b-2 border-transparent pb-3 text-sm font-medium text-text-muted transition-colors hover:text-text" %>
  </div>

  <div id="overview" data-tabs-target="panel">
    <%= render "bots/tabs/overview", bot: @bot, groups: @groups, invitations: @invitations %>
  </div>

  <div id="commands" data-tabs-target="panel" class="hidden">
    <%= render "bots/tabs/commands", bot: @bot %>
  </div>

  <div id="triggers" data-tabs-target="panel" class="hidden">
    <%= render "bots/tabs/triggers", bot: @bot %>
  </div>

  <div id="schedules" data-tabs-target="panel" class="hidden">
    <%= render "bots/tabs/schedules", bot: @bot %>
  </div>

  <div id="files" data-tabs-target="panel" class="hidden">
    <%= render "bots/tabs/files", bot: @bot, tree: @tree, total_usage: @total_usage %>
  </div>

  <div id="logs" data-tabs-target="panel" class="hidden">
    <%= render "bots/tabs/logs", bot: @bot, logs: @logs, groups: @groups %>
  </div>
</div>
