<div class="mb-4 flex items-center justify-between">
  <h2 class="text-lg font-medium">Scheduled Actions</h2>
  <%= link_to "New scheduled action", new_bot_scheduled_action_path(bot),
    class: "rounded-md bg-primary px-4 py-2 text-sm font-medium text-white hover:bg-primary-hover transition-colors" %>
</div>

<% if bot.scheduled_actions.any? %>
  <div class="rounded-lg border border-border bg-surface-raised overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-border text-left text-text-muted">
          <th class="px-4 py-3 font-medium">Name</th>
          <th class="px-4 py-3 font-medium">Schedule</th>
          <th class="px-4 py-3 font-medium">Enabled</th>
          <th class="px-4 py-3 font-medium">Last run</th>
          <th class="px-4 py-3 font-medium">Next run</th>
          <th class="px-4 py-3 font-medium">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <% bot.scheduled_actions.order(:name).each do |action| %>
          <tr class="hover:bg-surface-overlay transition-colors">
            <td class="px-4 py-3"><%= action.name %></td>
            <td class="px-4 py-3 font-mono text-xs"><%= action.schedule %></td>
            <td class="px-4 py-3">
              <span class="<%= action.enabled? ? 'text-success' : 'text-text-faint' %>">
                <%= action.enabled? ? "Yes" : "No" %>
              </span>
            </td>
            <td class="px-4 py-3 text-text-muted"><%= action.last_run_at&.to_fs(:short) || "Never" %></td>
            <td class="px-4 py-3 text-text-muted"><%= action.next_run_at&.to_fs(:short) || "Not scheduled" %></td>
            <td class="flex gap-2 px-4 py-3">
              <%= link_to "Edit", edit_bot_scheduled_action_path(bot, action),
                class: "text-xs text-primary hover:text-primary-hover" %>
              <%= button_to "Delete", bot_scheduled_action_path(bot, action), method: :delete,
                data: { turbo_confirm: "Are you sure?" },
                class: "text-xs text-danger hover:text-danger-hover" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="rounded-lg border border-border bg-surface-raised p-6 text-center text-sm text-text-faint">No scheduled actions yet.</p>
<% end %>
