<%# locals: (bot:, tree:, total_usage:) -%>
<div class="mb-4 flex flex-wrap items-center justify-between gap-4">
  <div class="flex items-center gap-4">
    <h2 class="text-lg font-medium">Files</h2>
    <span class="text-xs text-text-muted">
      <%= number_to_human_size(total_usage) %> / <%= number_to_human_size(ScriptFiles::MAX_TOTAL_SIZE) %>
    </span>
    <div class="h-1.5 w-32 rounded-full bg-surface-overlay overflow-hidden">
      <% pct = total_usage > 0 ? (total_usage.to_f / ScriptFiles::MAX_TOTAL_SIZE * 100).clamp(0, 100) : 0 %>
      <div class="h-full rounded-full <%= pct > 90 ? 'bg-danger' : 'bg-primary' %>" style="width: <%= pct %>%"></div>
    </div>
  </div>
</div>

<%= form_with url: bot_files_path(bot), method: :post, multipart: true,
  data: { turbo: false },
  class: "mb-6 flex items-center gap-3" do |f| %>
  <%= f.file_field :file, class: "text-sm text-text-muted file:mr-3 file:rounded-md file:border-0 file:bg-primary file:px-4 file:py-2 file:text-sm file:font-medium file:text-white file:cursor-pointer hover:file:bg-primary-hover file:transition-colors" %>
  <%= f.submit "Upload", class: "rounded-md bg-primary px-4 py-2 text-sm font-medium text-white hover:bg-primary-hover transition-colors cursor-pointer" %>
<% end %>

<% if tree.any? %>
  <div class="rounded-lg border border-border bg-surface-raised overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-border text-left text-text-muted">
          <th class="px-4 py-3 font-medium">Name</th>
          <th class="px-4 py-3 font-medium text-right">Size</th>
          <th class="px-4 py-3 font-medium">Modified</th>
          <th class="px-4 py-3 font-medium">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <% tree.each do |entry| %>
          <tr class="hover:bg-surface-overlay transition-colors">
            <td class="px-4 py-3 font-mono text-xs">
              <span style="padding-left: <%= entry[:depth] * 1.25 %>rem" class="inline-flex items-center gap-1.5">
                <% if entry[:dir] %>
                  <svg class="h-4 w-4 text-primary" viewBox="0 0 20 20" fill="currentColor"><path d="M3.75 3A1.75 1.75 0 0 0 2 4.75v3.26a3.235 3.235 0 0 1 1.75-.51h12.5c.644 0 1.245.188 1.75.51V6.75A1.75 1.75 0 0 0 16.25 5h-4.836a.25.25 0 0 1-.177-.073L9.823 3.513A1.75 1.75 0 0 0 8.586 3H3.75Z"/><path d="M3.75 9A1.75 1.75 0 0 0 2 10.75v4.5c0 .966.784 1.75 1.75 1.75h12.5A1.75 1.75 0 0 0 18 15.25v-4.5A1.75 1.75 0 0 0 16.25 9H3.75Z"/></svg>
                  <span class="text-text-muted"><%= entry[:name] %></span>
                <% else %>
                  <svg class="h-4 w-4 text-text-faint" viewBox="0 0 20 20" fill="currentColor"><path d="M3 3.5A1.5 1.5 0 0 1 4.5 2h6.879a1.5 1.5 0 0 1 1.06.44l4.122 4.12A1.5 1.5 0 0 1 17 7.622V16.5a1.5 1.5 0 0 1-1.5 1.5h-11A1.5 1.5 0 0 1 3 16.5v-13Z"/></svg>
                  <span><%= entry[:name] %></span>
                <% end %>
              </span>
            </td>
            <td class="px-4 py-3 text-right text-xs text-text-muted whitespace-nowrap">
              <%= entry[:size] ? number_to_human_size(entry[:size]) : "" %>
            </td>
            <td class="px-4 py-3 text-xs text-text-muted whitespace-nowrap">
              <%= entry[:modified].strftime("%b %d, %Y") %>
            </td>
            <td class="px-4 py-3">
              <% unless entry[:dir] %>
                <div class="flex items-center gap-3">
                  <%= link_to "Download", download_bot_files_path(bot, path: entry[:path]),
                    class: "text-xs text-primary hover:text-primary-hover" %>
                  <%= link_to "Delete", bot_files_path(bot, path: entry[:path]),
                    data: { turbo_method: :delete, turbo_confirm: "Delete #{entry[:name]}?" },
                    class: "text-xs text-danger hover:text-danger-hover" %>
                </div>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="rounded-lg border border-border bg-surface-raised p-8 text-center">
    <p class="text-text-muted mb-2">No files yet.</p>
    <p class="text-sm text-text-faint mb-4">Upload files here to make them available in your bot's scripts via the <code class="text-primary">files</code> API.</p>
    <div class="inline-block rounded bg-surface px-4 py-3 text-left font-mono text-xs text-text">
      <span class="text-text-faint"># Read an uploaded file</span><br>
      data = JSON.parse(files.read("<span class="text-primary">config.json</span>"))<br>
      <br>
      <span class="text-text-faint"># Write a file from your script</span><br>
      files.write("<span class="text-primary">log.txt</span>", "Processed at #{Time.now}")
    </div>
  </div>
<% end %>
