<div class="mb-4 flex items-center justify-between">
  <h2 class="text-lg font-medium">Message Logs</h2>
</div>

<%= render "message_logs/filter", bot: bot %>

<% if logs.any? %>
  <div class="rounded-lg border border-border bg-surface-raised overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-border text-left text-text-muted">
          <th class="px-4 py-3 font-medium">Time</th>
          <th class="px-4 py-3 font-medium">Direction</th>
          <th class="px-4 py-3 font-medium">Group ID</th>
          <th class="px-4 py-3 font-medium">Author</th>
          <th class="px-4 py-3 font-medium">Content</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <% logs.each do |log| %>
          <tr class="hover:bg-surface-overlay transition-colors">
            <td class="px-4 py-3 text-text-muted"><%= log.message_at.to_fs(:short) %></td>
            <td class="px-4 py-3">
              <span class="<%= log.direction == 'incoming' ? 'text-primary' : 'text-success' %>"><%= log.direction.capitalize %></span>
            </td>
            <td class="px-4 py-3 font-mono text-xs text-text-faint"><%= truncate(log.group_id, length: 20) %></td>
            <td class="px-4 py-3 text-text-muted"><%= truncate(log.author, length: 20) %></td>
            <td class="px-4 py-3"><%= truncate(log.content, length: 80) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="rounded-lg border border-border bg-surface-raised p-6 text-center text-sm text-text-faint">No message logs found.</p>
<% end %>
