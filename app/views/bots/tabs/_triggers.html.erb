<div class="mb-4 flex items-center justify-between">
  <h2 class="text-lg font-medium">Triggers</h2>
  <%= link_to "New trigger", new_bot_trigger_path(bot),
    class: "rounded-md bg-primary px-4 py-2 text-sm font-medium text-white hover:bg-primary-hover transition-colors" %>
</div>

<% if bot.triggers.any? %>
  <div class="rounded-lg border border-border bg-surface-raised overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-border text-left text-text-muted">
          <th class="px-4 py-3 font-medium">Name</th>
          <th class="px-4 py-3 font-medium">Condition</th>
          <th class="px-4 py-3 font-medium">Enabled</th>
          <th class="px-4 py-3 font-medium">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <% bot.triggers.order(:position).each do |trigger| %>
          <tr class="hover:bg-surface-overlay transition-colors">
            <td class="px-4 py-3"><%= trigger.name %></td>
            <td class="px-4 py-3">
              <%= trigger.condition_type.humanize %>
              <% if trigger.condition_value.present? %>
                <span class="ml-1 font-mono text-xs text-text-faint"><%= trigger.condition_value %></span>
              <% end %>
            </td>
            <td class="px-4 py-3">
              <%= render "shared/toggle_enabled", record: trigger, url: toggle_enabled_bot_trigger_path(bot, trigger) %>
            </td>
            <td class="px-4 py-3">
              <div class="flex items-center gap-3">
                <%= link_to "Edit", edit_bot_trigger_path(bot, trigger),
                  class: "text-xs text-primary hover:text-primary-hover" %>
                <%= link_to "Delete", bot_trigger_path(bot, trigger),
                  data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                  class: "text-xs text-danger hover:text-danger-hover" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="rounded-lg border border-border bg-surface-raised p-8 text-center">
    <p class="text-text-muted mb-4">No triggers yet. Triggers react to events like new messages or members joining.</p>
    <%= link_to "Create a trigger", new_bot_trigger_path(bot),
      class: "rounded-md bg-primary px-4 py-2 text-sm font-medium text-white hover:bg-primary-hover transition-colors" %>
  </div>
<% end %>
