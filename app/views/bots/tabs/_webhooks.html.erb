<div class="mb-4 flex items-center justify-between">
  <h2 class="text-lg font-medium">Webhook Endpoints</h2>
  <%= link_to "New endpoint", new_bot_webhook_endpoint_path(bot),
    class: "rounded-md bg-primary px-4 py-2 text-sm font-medium text-white hover:bg-primary-hover transition-colors" %>
</div>

<% if bot.webhook_endpoints.any? %>
  <div class="rounded-lg border border-border bg-surface-raised overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-border text-left text-text-muted">
          <th class="px-4 py-3 font-medium">Name</th>
          <th class="px-4 py-3 font-medium">URL</th>
          <th class="px-4 py-3 font-medium">Enabled</th>
          <th class="px-4 py-3 font-medium">Deliveries</th>
          <th class="px-4 py-3 font-medium">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        <% bot.webhook_endpoints.left_joins(:webhook_deliveries).group(:id).order(:name).select("webhook_endpoints.*, COUNT(webhook_deliveries.id) AS deliveries_count").each do |endpoint| %>
          <tr class="hover:bg-surface-overlay transition-colors">
            <td class="px-4 py-3"><%= endpoint.name %></td>
            <td class="px-4 py-3 font-mono text-xs text-text-muted"><%= truncate(endpoint.url, length: 50) %></td>
            <td class="px-4 py-3">
              <span class="<%= endpoint.enabled? ? 'text-success' : 'text-text-faint' %>">
                <%= endpoint.enabled? ? "Yes" : "No" %>
              </span>
            </td>
            <td class="px-4 py-3 text-text-muted"><%= endpoint.deliveries_count %></td>
            <td class="flex gap-2 px-4 py-3">
              <%= link_to "Edit", edit_bot_webhook_endpoint_path(bot, endpoint),
                class: "text-xs text-primary hover:text-primary-hover" %>
              <%= button_to "Delete", bot_webhook_endpoint_path(bot, endpoint), method: :delete,
                data: { turbo_confirm: "Are you sure?" },
                class: "text-xs text-danger hover:text-danger-hover" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="rounded-lg border border-border bg-surface-raised p-6 text-center text-sm text-text-faint">No webhook endpoints yet.</p>
<% end %>
